# Variáveis de ambiente (criar .env baseado neste arquivo)

# Porta do servidor (Render usa a variável PORT automaticamente)
PORT=3000

# Segredo para assinar os JWTs (cookies de login)
# IMPORTANTE: gerar um valor longo e aleatório em produção
# Exemplo: openssl rand -base64 32
JWT_SECRET=troque-este-valor-em-producao

# Caminho do arquivo SQLite
DB_PATH=./db.sqlite

# Usuário admin inicial — usado APENAS quando o banco está vazio
# Após o 1º login, troque a senha pelo painel admin
ADMIN_USERNAME=joao paiva
ADMIN_PASSWORD=858646

# Em produção (https), exige cookies seguros
NODE_ENV=development
