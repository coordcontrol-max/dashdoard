# Variáveis de ambiente — copie pra .env e preencha

# === OBRIGATÓRIAS ===

# Connection string do Postgres (do Render → seu banco → External Database URL pra rodar local,
# Internal Database URL pra rodar no próprio Render)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Segredo pra assinar tokens JWT (gere com: openssl rand -base64 32)
JWT_SECRET=troque-este-valor-por-algo-aleatorio-longo

# === ADMIN INICIAL ===
# Usado APENAS no 1º start, quando o banco está vazio.
# Depois, troque a senha pelo painel admin do site.
ADMIN_USERNAME=joao paiva
ADMIN_PASSWORD=858646

# === UPLOAD DE DADOS (rodando os scripts atualizar_*.sh local) ===
# URL pública do site (Render dará uma URL tipo https://margem-XXXX.onrender.com)
SITE_URL=https://margem-paiva.onrender.com

# === CONFIG ===
PORT=3000
NODE_ENV=development   # use "production" no Render
